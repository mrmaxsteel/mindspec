# MindSpec local runtime files — not version-controlled.
# Phase is stored per-spec in lifecycle.yaml (committed). These are transient.
.mindspec/session.json
.mindspec/focus
.mindspec/current-spec.json

# Beads runtime artifacts are handled by .beads/.gitignore
# This rule catches any stray runtime files outside .beads/
**/bd.sock

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
ENV/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Go
bin/
/mindspec
*.exe

# OS
.DS_Store
Thumbs.db

# beads git submodule
beads/

# mindspec worktrees
.worktrees/

# local harness run artifacts
.harness_runs/
.harness-runs/
