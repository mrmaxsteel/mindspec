# MindSpec local runtime files — not version-controlled.
# Phase is derived from beads (ADR-0023). These are transient.
.mindspec/session.json
.mindspec/current-spec.json

# Beads runtime artifacts are handled by .beads/.gitignore
# This rule catches any stray runtime files outside .beads/
**/bd.sock

# Stray beads export that the bd pre-commit hook occasionally drops at the
# repo root (the canonical copy lives at .beads/issues.jsonl).
/issues.jsonl

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
ENV/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Go
bin/
/mindspec
*.exe

# Go workspace files. Spec 084 removed the agentmind sibling
# materialization (see ADR-0027); these patterns remain so any
# locally-generated go.work from a stale checkout is still ignored.
/go.work
/go.work.sum

# OS
.DS_Store
Thumbs.db

# beads git submodule
beads/

# mindspec worktrees
.worktrees/

# local harness run artifacts
.harness_runs/
.harness-runs/

# Dolt database files (added by bd init)
.dolt/
*.db

# Beads / Dolt files (added by bd init)
.beads-credential-key
