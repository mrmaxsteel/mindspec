# Mindspec local state — state.json is committed (project-level workflow state)
# Only ignore runtime/temp files if any are added later
.mindspec/current-spec.json

# Beads runtime artifacts are handled by .beads/.gitignore
# This rule catches any stray runtime files outside .beads/
**/bd.sock

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
ENV/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Worktrees
worktree-*/

# Go
bin/
*.exe

# OS
.DS_Store
Thumbs.db
