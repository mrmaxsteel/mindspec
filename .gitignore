# Mindspec local state — state.json is a local runtime cursor (ADR-0015),
# not version-controlled. It contains machine-local paths (activeWorktree)
# and is derivable from molecules via `mindspec instruct`.
.mindspec/state.json
.mindspec/current-spec.json

# Beads runtime artifacts are handled by .beads/.gitignore
# This rule catches any stray runtime files outside .beads/
**/bd.sock

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
ENV/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Worktrees
worktree-*/

# Go
bin/
*.exe

# OS
.DS_Store
Thumbs.db

# beads git submodule
beads/
# mindspec worktrees
.worktrees/
# bd worktree
.worktrees/worktree-mindspec-u7mk/
# bd worktree
worktree-mindspec-u7mk/
# bd worktree
.worktrees/worktree-mindspec-mol-41m89.1/
