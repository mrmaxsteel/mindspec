+func adrWithDomains(id, title, domains string) string {
+	return "# " + id + ": " + title + "\n\n" +
+		"- **Date**: 2026-06-01\n" +
+		"- **Status**: Accepted\n" +
+		"- **Domain(s)**: " + domains + "\n" +
